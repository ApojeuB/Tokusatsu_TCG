{
  "expo": {
    "name": "Tokusatsu TCG",
    "slug": "tokusatsu-tcg",
    "version": "1.0.0",
    "orientation": "landscape",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": [
      "**/*"
    ],
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tokusatsu.tcg"
    },
    "android": {
      "package": "com.tokusatsu.tcg",
      "adaptiveIcon": {
        "backgroundColor": "#1a1a2e"
      }
    },
    "web": {},
    "plugins": [
      "expo-router"
    ],
    "extra": {
      "eas": {
        "projectId": "tokusatsu-tcg-local"
      }
    }
  }
}
